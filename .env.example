# Conexión de la landing con el SaaS (mismo proyecto Supabase que la app).
# Con estas variables VACÍAS, la landing sigue funcionando en "modo demo"
# (los formularios simulan el alta y no crean nada real).

# Proyecto Supabase (fuente de verdad, compartido con el SaaS).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# URL de la app del SaaS, para redirigir al cliente tras el alta/pago.
VITE_APP_URL=https://app.ifpos.app
