# =====================================================================
# Variables del BACKEND de la landing (Vercel Serverless /api).
# Se cargan en Vercel → Project Settings → Environment Variables.
# ⚠️ NINGUNA lleva prefijo VITE_ → nunca se exponen al frontend.
# El frontend no necesita variables: llama a /api del mismo dominio.
# =====================================================================

# Proyecto Supabase del SaaS (el de Nacho). SERVICE_ROLE es SECRETA (solo backend).
SUPABASE_URL=https://epsotvywoklcaqbdvxrv.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Mercado Pago — cuenta de la PLATAFORMA (cobra la suscripción).
MP_ACCESS_TOKEN=

# URL pública de la landing (para back_urls y notification_url de MP).
LANDING_URL=https://ifpos.app

# URL de la app del SaaS (a donde vuelve el cliente al definir su contraseña).
APP_URL=https://app.ifpos.app
