---
import Section from './Section.astro'
import { quickMetrics } from '@/data/metrics'
---

<Section spacing="tight">
  <div class="grid grid-cols-2 gap-3 md:grid-cols-3 lg:grid-cols-6">
    {
      quickMetrics.map(({ icon: Icon, value, prefix, suffix, label }, i) => (
        <div
          data-reveal
          style={`--reveal-delay: ${i * 0.06}s`}
          class="card card-hover group rounded-[var(--radius-lg)] p-5"
        >
          <span class="icon-chip size-10 rounded-xl transition-colors group-hover:accent-gradient group-hover:text-[#04121f]">
            <Icon className="size-5" />
          </span>
          <p class="mt-4 text-2xl font-bold text-fg">
            <span class="tnum" data-count={value} data-prefix={prefix ?? ''} data-suffix={suffix ?? ''}>
              {prefix}0{suffix}
            </span>
          </p>
          <p class="mt-1 text-xs leading-snug text-muted">{label}</p>
        </div>
      ))
    }
  </div>
</Section>
