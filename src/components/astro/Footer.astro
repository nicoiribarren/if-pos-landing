---
import { Mail, MessageCircle, MapPin, AtSign, Globe, Share2, ArrowRight } from 'lucide-react'
import { navLinks } from '@/config/nav'
import { site } from '@/config/site'

const featureLinks = ['Punto de venta', 'Caja', 'Stock', 'Clientes', 'Reportes', 'Usuarios']
const year = new Date().getFullYear()
const socials = [AtSign, Globe, Share2]
---

<footer class="relative border-t border-[var(--color-line)] bg-[var(--color-bg-soft)]">
  <div class="container-page py-14">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-[1.4fr_1fr_1fr_1fr]">
      <div>
        <span class="inline-flex items-center gap-2.5">
          <span class="relative grid size-9 place-items-center rounded-[10px] border border-[var(--color-line-strong)] bg-[var(--color-bg-soft)]">
            <svg width="20" height="20" viewBox="0 0 32 32" fill="none" aria-hidden="true">
              <path d="M9 9H12V23H9V9Z" fill="url(#fg1)"></path>
              <path d="M15 9H24V11.6H18V14.4H23V17H18V23H15V9Z" fill="#F8FAFC"></path>
              <defs>
                <linearGradient id="fg1" x1="6" y1="8" x2="26" y2="24" gradientUnits="userSpaceOnUse">
                  <stop stop-color="#3B82F6"></stop>
                  <stop offset="1" stop-color="#22D3EE"></stop>
                </linearGradient>
              </defs>
            </svg>
          </span>
          <span class="flex flex-col leading-none">
            <span class="font-display text-[15px] font-bold tracking-tight text-fg">{site.productName}</span>
            <span class="mt-0.5 text-[10px] font-medium uppercase tracking-[0.14em] text-faint">by {site.company}</span>
          </span>
        </span>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-muted">
          Un sistema de ventas, caja, stock, clientes y reportes para que cada comercio tenga su propio espacio dentro
          de una plataforma moderna.
        </p>
        <div class="mt-5 flex gap-2">
          {
            socials.map((Icon) => (
              <button
                type="button"
                class="grid size-9 cursor-pointer place-items-center rounded-full border border-[var(--color-line)] text-muted transition-colors hover:border-[var(--color-accent-bright)] hover:text-fg"
                aria-label="Red social"
              >
                <Icon className="size-4" />
              </button>
            ))
          }
        </div>
      </div>

      <div>
        <h4 class="mb-4 text-sm font-semibold text-fg">Navegación</h4>
        <div class="flex flex-col gap-2.5 text-sm">
          {
            navLinks.map((l) => (
              <a href={`#${l.id}`} class="text-muted transition-colors hover:text-fg">
                {l.label}
              </a>
            ))
          }
        </div>
      </div>

      <div>
        <h4 class="mb-4 text-sm font-semibold text-fg">Funcionalidades</h4>
        <div class="flex flex-col gap-2.5 text-sm">
          {
            featureLinks.map((f) => (
              <a href="#funcionalidades" class="text-muted transition-colors hover:text-fg">
                {f}
              </a>
            ))
          }
        </div>
      </div>

      <div>
        <h4 class="mb-4 text-sm font-semibold text-fg">Contacto</h4>
        <div class="flex flex-col gap-2.5 text-sm">
          <a href={`mailto:${site.contactEmail}`} class="flex items-center gap-2 text-muted transition-colors hover:text-fg">
            <Mail className="size-4" />
            {site.contactEmail}
          </a>
          <button type="button" data-modal="whatsapp" class="flex cursor-pointer items-center gap-2 text-left text-muted transition-colors hover:text-fg">
            <MessageCircle className="size-4" />
            {site.whatsapp}
          </button>
          <span class="flex items-center gap-2 text-muted">
            <MapPin className="size-4" />
            {site.location}
          </span>
          <button
            type="button"
            data-modal="create"
            class="mt-1 inline-flex cursor-pointer items-center gap-1.5 text-[var(--color-accent-bright)] transition-colors hover:text-[var(--color-cyan)]"
          >
            Crear mi negocio
            <ArrowRight className="size-4" />
          </button>
        </div>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-start justify-between gap-4 border-t border-[var(--color-line)] pt-6 sm:flex-row sm:items-center">
      <p class="text-xs text-faint">
        © {year} {site.productName}. Powered by {site.company}. Hecho en {site.location}.
      </p>
      <span class="inline-flex items-center gap-1.5 whitespace-nowrap rounded-full border border-[rgba(251,191,36,0.3)] bg-[rgba(251,191,36,0.1)] px-3 py-1 text-xs font-medium text-[var(--color-warning)]">
        Modo demo · sin integraciones reales
      </span>
    </div>
  </div>
</footer>
