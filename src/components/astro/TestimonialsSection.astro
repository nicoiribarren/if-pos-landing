---
import { Star } from 'lucide-react'
import Section from './Section.astro'
import SectionHeader from './SectionHeader.astro'
import { testimonials } from '@/data/testimonials'
---

<Section>
  <SectionHeader
    eyebrow="Testimonios"
    description="Casos representativos del tipo de comercio para el que está pensado el sistema."
  >
    Negocios que ya <span class="text-gradient">ordenaron</span> su operación
  </SectionHeader>

  <div class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {
      testimonials.map((t, i) => (
        <figure
          data-reveal
          style={`--reveal-delay: ${(i % 3) * 0.08}s`}
          class="flex flex-col rounded-[var(--radius-lg)] border border-[var(--color-line)] bg-[var(--color-surface)] p-6 transition-all duration-300 hover:-translate-y-1 hover:border-[var(--color-line-strong)]"
        >
          <div class="flex gap-0.5">
            {Array.from({ length: t.rating }).map(() => (
              <Star className="size-4 fill-[var(--color-warning)] text-[var(--color-warning)]" />
            ))}
          </div>
          <blockquote class="mt-4 flex-1 text-sm leading-relaxed text-fg">"{t.quote}"</blockquote>
          <figcaption class="mt-5 flex items-center gap-3 border-t border-[var(--color-line)] pt-4">
            <span
              class="grid size-10 place-items-center rounded-full text-xs font-bold text-[#04121f]"
              style={`background: ${t.accent}`}
            >
              {t.initials}
            </span>
            <div>
              <p class="text-sm font-semibold text-fg">{t.name}</p>
              <p class="text-xs text-faint">
                {t.role} en {t.business}
              </p>
            </div>
          </figcaption>
        </figure>
      ))
    }
  </div>
</Section>
