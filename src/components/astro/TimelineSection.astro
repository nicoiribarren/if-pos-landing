---
import Section from './Section.astro'
import SectionHeader from './SectionHeader.astro'
import { timeline, timelineDisclaimer } from '@/data/content'
---

<Section class="bg-[var(--color-bg-soft)]/40">
  <SectionHeader description="Un recorrido posible desde que elegís el plan hasta que empezás a analizar tus reportes.">
    En marcha <span class="text-gradient">el mismo día</span>
  </SectionHeader>

  <div class="relative mt-16">
    <div class="absolute left-0 right-0 top-5 hidden h-px bg-[var(--color-line)] lg:block"></div>
    <div data-reveal class="timeline-line absolute left-0 right-0 top-5 hidden h-px origin-left accent-gradient lg:block"></div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-7 lg:gap-3">
      {
        timeline.map((t, i) => (
          <div data-reveal style={`--reveal-delay: ${i * 0.08}s`} class="relative">
            <span class="relative z-10 grid size-10 place-items-center rounded-full border border-[var(--color-line-strong)] bg-[var(--color-surface)] text-xs font-bold text-[var(--color-accent-bright)]">
              {i + 1}
            </span>
            <p class="mt-4 text-xs font-semibold text-[var(--color-cyan)]">{t.time}</p>
            <p class="mt-1 text-sm text-fg">{t.title}</p>
          </div>
        ))
      }
    </div>
  </div>

  <p class="mx-auto mt-10 max-w-2xl text-center text-xs text-faint">{timelineDisclaimer}</p>
</Section>

<style>
  /* La línea se dibuja al entrar en viewport. Sobrescribe el translateY del
     [data-reveal] global para no pelear por `transform`. */
  .timeline-line[data-reveal] {
    opacity: 1;
    transform: scaleX(0);
    transition: transform 1.2s var(--ease-out-expo) 0.2s;
  }
  .timeline-line[data-reveal].in-view {
    transform: scaleX(1);
  }
</style>
