---
import { ArrowRight, PlayCircle, MessageCircle } from 'lucide-react'

const perks = ['Sin instalar nada', 'Planes mensuales', 'Datos separados por negocio', 'Instalable como PWA']
---

<section class="relative overflow-hidden py-24 md:py-32">
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 overflow-hidden">
    <div class="animate-aurora absolute -top-40 left-1/4 size-[38rem] rounded-full bg-[radial-gradient(circle,rgba(59,130,246,0.32),transparent_65%)] blur-2xl"></div>
    <div class="animate-aurora absolute -top-20 right-1/5 size-[32rem] rounded-full bg-[radial-gradient(circle,rgba(34,211,238,0.24),transparent_65%)] blur-2xl [animation-delay:-7s]"></div>
    <div class="animate-aurora absolute left-1/2 top-40 size-[34rem] -translate-x-1/2 rounded-full bg-[radial-gradient(circle,rgba(139,92,246,0.2),transparent_65%)] blur-3xl [animation-delay:-13s]"></div>
  </div>
  <div
    aria-hidden="true"
    class="grid-lines pointer-events-none absolute inset-0 opacity-60"
    style="-webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 40%, #000 30%, transparent 75%); mask-image: radial-gradient(ellipse 80% 60% at 50% 40%, #000 30%, transparent 75%)"
  >
  </div>

  <div class="container-page relative z-10">
    <div data-reveal class="glass mx-auto max-w-4xl rounded-[var(--radius-xl)] p-10 text-center sm:p-14">
      <h2 class="text-3xl font-bold leading-tight text-fg sm:text-4xl md:text-5xl">
        Tu negocio puede <span class="text-gradient">vender mejor</span> desde hoy
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-muted sm:text-lg">
        Creá tu espacio dentro de la plataforma y empezá a ordenar ventas, caja, stock, clientes y reportes con un
        sistema moderno y simple de usar.
      </p>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <button
          type="button"
          data-modal="create"
          class="inline-flex h-13 cursor-pointer items-center justify-center gap-2 whitespace-nowrap rounded-full bg-gradient-to-r from-[#2563eb] to-[#3b82f6] px-7 text-base font-semibold text-white shadow-[0_8px_30px_-8px_rgba(37,99,235,0.6)] transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_10px_40px_-8px_rgba(34,211,238,0.55)] active:scale-[0.97]"
        >
          Crear mi negocio
          <ArrowRight className="size-4" />
        </button>
        <button
          type="button"
          data-modal="demo"
          class="glass inline-flex h-13 cursor-pointer items-center justify-center gap-2 whitespace-nowrap rounded-full px-7 text-base font-semibold text-fg transition-all duration-200 hover:-translate-y-0.5 hover:bg-white/[0.07] active:scale-[0.97]"
        >
          <PlayCircle className="size-4" />
          Pedir demo
        </button>
        <a
          href="#planes"
          class="inline-flex h-13 items-center justify-center whitespace-nowrap rounded-full px-7 text-base font-semibold text-muted transition-colors hover:bg-white/[0.04] hover:text-fg"
        >
          Ver planes
        </a>
      </div>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-xs text-faint">
        {
          perks.map((p) => (
            <span class="inline-flex items-center gap-1.5">
              <span class="size-1.5 rounded-full accent-gradient" />
              {p}
            </span>
          ))
        }
      </div>

      <button
        type="button"
        data-modal="whatsapp"
        class="mx-auto mt-8 inline-flex cursor-pointer items-center gap-2 text-sm font-medium text-[var(--color-success)] transition-colors hover:text-[var(--color-cyan)]"
      >
        <MessageCircle className="size-4" />
        Hablar por WhatsApp
      </button>
    </div>
  </div>
</section>
