---
import Section from './Section.astro'
import SectionHeader from './SectionHeader.astro'
import { onboardingSteps } from '@/data/content'
---

<Section id="como-funciona">
  <SectionHeader description="Un camino simple, paso a paso, desde crear tu cuenta hasta analizar tus primeros reportes.">
    De registrarte a vender <span class="text-gradient">en minutos</span>
  </SectionHeader>

  <div class="relative mx-auto mt-16 max-w-3xl">
    <!-- Track vertical -->
    <div class="absolute bottom-2 left-[19px] top-2 w-px bg-[var(--color-line)] md:left-1/2 md:-translate-x-1/2"></div>
    <div class="onboarding-line absolute bottom-2 left-[19px] top-2 w-px origin-top accent-gradient md:left-1/2 md:-translate-x-1/2"></div>

    <div class="space-y-6 md:space-y-8">
      {
        onboardingSteps.map((s, i) => (
          <div data-reveal style={`--reveal-delay: ${Math.min(i * 0.05, 0.2)}s`} class="relative md:grid md:grid-cols-2 md:gap-14">
            <span class="absolute left-0 top-0 z-10 grid size-10 place-items-center rounded-full border border-[var(--color-line-strong)] bg-[var(--color-surface)] text-sm font-bold text-[var(--color-accent-bright)] md:left-1/2 md:-translate-x-1/2">
              {s.n}
            </span>
            <div
              class:list={[
                'group ml-14 rounded-[var(--radius-lg)] border border-[var(--color-line)] bg-[var(--color-surface)] p-5 transition-colors hover:border-[var(--color-line-strong)] md:ml-0',
                i % 2 === 0 ? 'md:col-start-1 md:text-right' : 'md:col-start-2',
              ]}
            >
              <h3 class="font-semibold text-fg">{s.title}</h3>
              <p class="mt-1 text-sm text-muted">{s.text}</p>
              <p class="mt-2 text-xs text-[var(--color-cyan)] opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                {s.detail}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</Section>

<style>
  /* La línea se dibuja siguiendo el scroll (CSS scroll-driven). Fallback: llena. */
  .onboarding-line {
    transform: scaleY(1);
  }
  @supports (animation-timeline: view()) {
    .onboarding-line {
      animation: onboarding-draw linear both;
      animation-timeline: view();
      animation-range: entry 20% exit 60%;
    }
    @keyframes onboarding-draw {
      from {
        transform: scaleY(0);
      }
      to {
        transform: scaleY(1);
      }
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .onboarding-line {
      animation: none;
      transform: scaleY(1);
    }
  }
</style>
